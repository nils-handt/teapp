{
  "name": "teapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:sandbox": "vitest run --configLoader native --pool threads -c vite.config.ts",
    "testH": "vitest",
    "qa:scale-reconnect": "playwright test tests/e2e/scale-reconnect.spec.ts --config=playwright.config.ts --project=chrome-debug --headed",
    "qa:scale-reconnect:control": "playwright test tests/e2e/scale-reconnect.spec.ts --config=playwright.config.ts --project=chromium-debug --headed"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^7.3.0",
    "@capacitor-community/keep-awake": "^7.1.0",
    "@capacitor-community/sqlite": "^7.0.3",
    "@capacitor/android": "^7.4.5",
    "@capacitor/core": "^7.4.5",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/ios": "^7.4.5",
    "@capacitor/share": "^7.0.0",
    "@ionic/react": "8.7.17",
    "@ionic/react-router": "8.7.17",
    "ionicons": "^8.0.13",
    "match-sorter": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "sql.js": "^1.11.0",
    "typeorm": "^0.3.28",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@eslint/compat": "^1.4.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-react": "^5.1.2",
    "dygraphs": "^2.2.1",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "identity-obj-proxy": "^3.0.0",
    "jeep-sqlite": "^2.8.0",
    "jsdom": "^27.4.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vitest": "^4.0.18"
  }
}
